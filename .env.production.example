# ============================================================================
# Botilleria Core — Production Environment Variables
# ============================================================================
# Copy this file to botilleria_core/.env and fill in the values
# ============================================================================

# ── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string (shared with Windmill)
DATABASE_URL=postgresql://windmill:windmill@booking-titanium-wm-db-1:5432/botilleria

# Enable SQL query logging (false for production)
DB_ECHO=false

# ── LLM — OpenRouter ───────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-YOUR_API_KEY_HERE

# Default model (overridden per-tenant by admin)
MODEL_NAME=openrouter/nvidia/nemotron-3-super-120b-a12b:free
MODEL_DISPLAY=nemotron-3-super-120b:free

# ── Default Tenant (seeded on first run) ───────────────────────────────────
DEFAULT_TENANT_SLUG=el_buen_trago
DEFAULT_TENANT_NAME=Botillería El Buen Trago
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── Application ────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
