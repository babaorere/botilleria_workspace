# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL=postgresql://windmill:windmill@db:5432/botilleria
DB_ECHO=false

# ── LLM — OpenRouter (LiteLlm, patrón wmill) ──────────────────
# Modelos free: openrouter/nvidia/nemotron-3-super-120b-a12b:free
# Modelos paid: openrouter/anthropic/claude-sonnet-4-20250514
OPENROUTER_API_KEY=your-openrouter-api-key
MODEL_NAME=openrouter/nvidia/nemotron-3-super-120b-a12b:free
MODEL_DISPLAY=nemotron-3-super-120b:free

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
