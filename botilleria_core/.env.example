# ── Base de datos ──────────────────────────────────────────────
DATABASE_URL=postgresql://windmill:windmill@db:5432/botilleria
DB_ECHO=false

# ── LLM — OpenRouter o NVIDIA NIM ──────────────────
NVIDIA_API_KEY=your-nvidia-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
MODEL_NAME=nvidia_nim/z-ai/glm-5.1
MODEL_DISPLAY=z-ai/glm-5.1

# ── Session backend / Redis ────────────────────────────────────
SESSION_BACKEND=redis
REDIS_URL=redis://redis:6379/0
REDIS_NAMESPACE=botilleria:adk:v1
REDIS_SESSION_TTL_SECONDS=86400
REDIS_LOCK_TIMEOUT_SECONDS=15
REDIS_LOCK_BLOCKING_TIMEOUT_SECONDS=5.0
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_SOCKET_TIMEOUT_SECONDS=5.0
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5.0
REDIS_MAX_CONNECTIONS=100
REDIS_RETRY_ATTEMPTS=3

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
ADMIN_API_KEY=your-super-secret-admin-key
ALLOWED_ORIGINS=*
